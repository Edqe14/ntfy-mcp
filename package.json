{
  "name": "ntfy-mcp",
  "version": "0.1.0",
  "description": "Standalone MCP server for sending ntfy.sh notifications",
  "homepage": "https://github.com/Edqe14/ntfy-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Edqe14/ntfy-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Edqe14/ntfy-mcp/issues"
  },
  "type": "module",
  "bin": {
    "ntfy-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "smoke:test": "node scripts/smoke-test.mjs dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ntfy",
    "notifications",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
